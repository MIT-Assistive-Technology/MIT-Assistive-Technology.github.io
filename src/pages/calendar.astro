---
// src/pages/calendar.astro
import BaseLayout from '@/layouts/BaseLayout'
import ListCategories from '@/components/ListCategories'
import TitlePage from '@/components/TitlePage'

const calendarId =
	'ZDkxYWY0NjFiN2NmMDVjZTYzNDdhNDBkYzc4ZmRkNDcwNmI4NDg1MTcwMzAwMWU3ZWI0Yjk0ZWRhYjNhZDNkZEBncm91cC5jYWxlbmRhci5nb29nbGUuY29t'
const encodedCalendarId = encodeURIComponent(calendarId)
const calendarEmbedUrl = `https://calendar.google.com/calendar/embed?src=${encodedCalendarId}&ctz=America%2FNew_York`
const calendarAddUrl = `https://calendar.google.com/calendar/render?cid=${encodedCalendarId}`
const calendarViewUrl = `https://calendar.google.com/calendar/u/0?cid=${encodedCalendarId}`
---

<BaseLayout title='Calendar'>
	<TitlePage title='Calendar' />
	<ListCategories activeCategory='Calendar' />

	<section class='max-w-[95%] mx-auto py-12 px-6'>
		<h1 class='text-3xl font-bold mb-6 text-center text-gray-900 dark:text-white'>
			MIT Assistive Technology Calendar
		</h1>
		<p class='mb-8 text-center text-gray-700 dark:text-gray-300 text-lg'>
			Stay up to date with all our events, meetings, and activities!
		</p>

		<!-- Add to Calendar Button -->
		<div class='mb-6 flex justify-center'>
			<a
				href={calendarAddUrl}
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5'
			>
				<svg class='w-5 h-5 mr-2' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M12 6v6m0 0v6m0-6h6m-6 0H6'></path>
				</svg>
				Add to Google Calendar
			</a>
		</div>

		<!-- Embedded Calendar -->
		<div class='flex justify-center'>
			<div
				class='bg-white dark:bg-gray-800 shadow-lg rounded-lg p-2 md:p-3 overflow-hidden w-[70vw] max-w-full'
			>
				<div class='relative w-full' style='padding-bottom: 70%; height: 0; overflow: hidden;'>
					<iframe
						src={calendarEmbedUrl}
						style='border: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;'
						width='1400'
						height='980'
						frameborder='0'
						scrolling='no'
						title='MIT Assistive Technology Calendar'></iframe>
				</div>
			</div>
		</div>

		<!-- Alternative View Link -->
		<div class='mt-6 text-center'>
			<a
				href={calendarViewUrl}
				target='_blank'
				rel='noopener noreferrer'
				class='inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium transition-colors'
			>
				Open in Google Calendar
				<svg class='w-4 h-4 ml-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14'></path>
				</svg>
			</a>
		</div>
	</section>
</BaseLayout>
